{
  "name": "@vmprint/web-fonts",
  "version": "1.1.0",
  "type": "module",
  "description": "Browser-first FontManager for VMPrint. Loads font binaries from URLs, data URIs, and remote font catalogs with optional IndexedDB caching.",
  "author": "cosmiciron",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cosmiciron/vmprint-font-managers.git",
    "directory": "web"
  },
  "bugs": {
    "url": "https://github.com/cosmiciron/vmprint-font-managers/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "tsx": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@vmprint/contracts": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
