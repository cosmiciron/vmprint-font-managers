{
  "name": "@vmprint/local-fonts",
  "version": "1.2.1",
  "type": "module",
  "description": "Local filesystem FontManager for VMPrint. Bundles common open-source fonts (Noto, Arimo, Tinos, Cousine, Carlito, Caladea, Courier Prime).",
  "author": "cosmiciron",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cosmiciron/vmprint-font-managers.git",
    "directory": "local"
  },
  "bugs": {
    "url": "https://github.com/cosmiciron/vmprint-font-managers/issues"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./config": {
      "import": {
        "types": "./dist/config.d.ts",
        "default": "./dist/config.js"
      },
      "require": {
        "types": "./dist/config.d.cts",
        "default": "./dist/config.cjs"
      }
    }
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/config.ts --format esm,cjs --dts --clean --shims && node scripts/generate-registry.mjs",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@vmprint/contracts": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
